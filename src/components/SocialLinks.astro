---

<ul class="flex items-center gap-3" aria-label="Social profiles">
  {
    links.map(({ label, href, path }) => (
      <li>
        <a
          href={href}
          class:list={[
            'flex items-center justify-center rounded-full border border-line text-ink-soft transition-colors hover:border-copper hover:text-copper focus-visible:outline-2 focus-visible:outline-copper',
            size === 'lg' ? 'h-12 w-12' : 'h-9 w-9',
          ]}
          aria-label={label}
        >
          <svg
            class:list={[size === 'lg' ? 'h-5 w-5' : 'h-4 w-4']}
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d={path} />
          </svg>
        </a>
      </li>
    ))
  }
</ul>
