---
interface Props {
  id: string;
  title: string;
  eyebrow?: string;
}

const { id, title, eyebrow } = Astro.props;
---

<section id={id} class="scroll-mt-20 border-t border-line">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
    {eyebrow && <p class="meta-label mb-2">{eyebrow}</p>}
    <h2 class="display-title mb-10 text-4xl sm:text-5xl">{title}</h2>
    <slot />
  </div>
</section>
