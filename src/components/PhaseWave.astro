---
/**
 * Signature motif: three sine waves offset by 120°, one per writing topic
 * (thoughts / energy / ai) — a three-phase system, as on a power grid.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['h-8 w-full max-w-xs', className]}
  viewBox="0 0 240 32"
  fill="none"
  aria-hidden="true"
>
  <path
    d="M0 16 C 20 -5, 40 -5, 60 16 S 100 37, 120 16 S 160 -5, 180 16 S 220 37, 240 16"
    stroke="var(--color-phase-thoughts)"
    stroke-width="1.5"
    opacity="0.9"
  ></path>
  <path
    d="M-40 16 C -20 -5, 0 -5, 20 16 S 60 37, 80 16 S 120 -5, 140 16 S 180 37, 200 16 S 240 -5, 260 16"
    stroke="var(--color-phase-energy)"
    stroke-width="1.5"
    opacity="0.9"
  ></path>
  <path
    d="M-80 16 C -60 -5, -40 -5, -20 16 S 20 37, 40 16 S 80 -5, 100 16 S 140 37, 160 16 S 200 -5, 220 16 S 260 37, 280 16"
    stroke="var(--color-phase-ai)"
    stroke-width="1.5"
    opacity="0.9"
  ></path>
</svg>
