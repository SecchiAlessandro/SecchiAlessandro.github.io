---
/**
 * Page-through album of the "domain knowledge" mind-map images.
 * Replaces the old custom album.js flipbook with a minimal pager.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const pages = Object.values(
  import.meta.glob<{ default: ImageMetadata }>('../assets/img/domain_knowledge/*.png', {
    eager: true,
  })
).map((mod) => mod.default);
---

<figure class="dk-album my-6 rounded-lg border border-line bg-white/70 p-4 shadow-sm">
  <div class="relative">
    {
      pages.map((page, i) => (
        <Image
          src={page}
          alt={`Domain knowledge mind map, page ${i + 1} of ${pages.length}`}
          class:list={['dk-page mx-auto h-auto max-w-full rounded', i > 0 && 'hidden']}
          data-page={i}
        />
      ))
    }
  </div>
  <figcaption class="mt-4 flex items-center justify-center gap-4">
    <button
      type="button"
      class="dk-prev rounded border border-line px-3 py-1 font-display text-sm font-medium uppercase tracking-wide text-ink transition-colors hover:border-copper hover:text-copper disabled:cursor-not-allowed disabled:opacity-40"
      disabled
    >
      Previous
    </button>
    <span class="dk-indicator meta-label">Page 1 of {pages.length}</span>
    <button
      type="button"
      class="dk-next rounded border border-line px-3 py-1 font-display text-sm font-medium uppercase tracking-wide text-ink transition-colors hover:border-copper hover:text-copper"
    >
      Next
    </button>
  </figcaption>
</figure>

<script>
  document.querySelectorAll<HTMLElement>('.dk-album').forEach((album) => {
    const pages = album.querySelectorAll<HTMLElement>('.dk-page');
    const prev = album.querySelector<HTMLButtonElement>('.dk-prev');
    const next = album.querySelector<HTMLButtonElement>('.dk-next');
    const indicator = album.querySelector<HTMLElement>('.dk-indicator');
    let current = 0;

    const show = (index: number) => {
      current = Math.max(0, Math.min(index, pages.length - 1));
      pages.forEach((page, i) => page.classList.toggle('hidden', i !== current));
      if (prev) prev.disabled = current === 0;
      if (next) next.disabled = current === pages.length - 1;
      if (indicator) indicator.textContent = `Page ${current + 1} of ${pages.length}`;
    };

    prev?.addEventListener('click', () => show(current - 1));
    next?.addEventListener('click', () => show(current + 1));
  });
</script>
