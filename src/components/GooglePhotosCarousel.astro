---
/**
 * Google Photos auto-advancing carousel, rendered by the publicalbum.js widget.
 * Same loader contract as GooglePhotosAlbum.astro.
 */
interface Props {
  link: string;
  title: string;
  description?: string;
  delay?: number;
  images: string[];
}

const { link, title, description, delay = 2, images } = Astro.props;
---

<div
  class="pa-carousel-widget my-6"
  style="width:100%; height:400px; display:none;"
  data-link={link}
  data-title={title}
  data-description={description}
  data-delay={String(delay)}
>
  {images.map((src) => <object data={src} aria-label={title}></object>)}
</div>

<script is:inline>
  if (!window.__publicAlbumLoaded) {
    window.__publicAlbumLoaded = true;
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/publicalbum@latest/embed-ui.min.js';
    s.async = true;
    document.head.appendChild(s);
  }
</script>
