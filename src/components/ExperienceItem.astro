---
interface Props {
  title: string;
  org?: string;
  period?: string;
  location?: string;
}

const { title, org, period, location } = Astro.props;
---

<div class="border-l-2 border-line py-1 pl-6">
  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <div>
      <h3 class="font-display text-2xl font-bold uppercase tracking-wide text-ink">{title}</h3>
      {org && <p class="text-base font-bold text-copper">{org}</p>}
    </div>
    {
      (period || location) && (
        <p class="meta-label shrink-0">
          {[period, location].filter(Boolean).join(' · ')}
        </p>
      )
    }
  </div>
  <div class="mt-3 space-y-3 text-ink-soft [&_a]:text-copper [&_a]:underline [&_a]:decoration-copper/40 [&_a:hover]:decoration-copper [&_li]:mt-1 [&_ul]:list-disc [&_ul]:pl-5">
    <slot />
  </div>
</div>
